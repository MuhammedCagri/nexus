{
    "name": "cagri/nexus",
    "authors": [                                                                                                                                                                                            
      {           
          "name": "Muhammed Çağrı Ağca",
          "email": "cagriagca051@gmail.com"                                                                                                                                                                    
      }                                                                                                                                                                                                   
    ],  
    "description": "High-performance, provider-agnostic LLM agent framework for PHP. Supports OpenAI, Anthropic, Ollama, and any OpenAI-compatible API.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "llm",
        "ai",
        "agent",
        "openai",
        "anthropic",
        "claude",
        "ollama",
        "gpt",
        "chatgpt",
        "machine-learning",
        "php",
        "tool-calling",
        "function-calling",
        "streaming"
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "suggest": {
        "psr/log": "For logging middleware support (^3.0)",
        "psr/simple-cache": "For cache middleware support (^3.0)"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
